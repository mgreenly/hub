APP=crm
MOUNT=/srv/crm/
DEFAULT=false
PORT=3001
# MCP=true marks this service for inclusion in the dashboard service inventory
MCP=true
# Event-plane outbox retention (event-protocol.md §11.3). A row is trimmed only
# when it is beyond BOTH horizons (the more-conservative floor wins). These match
# the eventplane library defaults; set explicitly so they are discoverable.
OUTBOX_RETENTION_DAYS=7
OUTBOX_RETENTION_MAX_ROWS=1000000
