#!/usr/bin/env bash
# bin/stop — stop the locally-running ledger started by bin/start.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env

PIDFILE="build/${APP}.pid"

if [[ ! -f "$PIDFILE" ]]; then
  echo "ledger not running (no pidfile)" >&2
  exit 0
fi

PID="$(cat "$PIDFILE")"
if kill -0 "$PID" 2>/dev/null; then
  kill "$PID"
  echo "ledger stopped (pid $PID)"
else
  echo "ledger not running (stale pidfile)" >&2
fi
rm -f "$PIDFILE"
