#!/usr/bin/env bash
# bin/build — produce the deploy artifacts for the ledger service.
#
# Outputs in $REPO/build/:
#   build/ledger      — shell wrapper that becomes /opt/ledger/bin/run
#                    (metaspot-launch exec()s this). Composes the public-origin
#                    LEDGER_RESOURCE_ID / LEDGER_AUTH_SERVER from METASPOT_DOMAIN and
#                    execs the real binary with its listen flags.
#   build/ledger.bin  — the Go binary (linux/amd64, static, stripped),
#                    shipped to /opt/ledger/bin/ledger.bin.
#
# metaspot-launch exec()s /opt/<app>/bin/run with no args (it has already sourced
# /etc/metaspot/env and manifest.env, so METASPOT_DOMAIN and PORT are in the env).
# ledger has no secrets and no SSM app-config key — it trusts the identity headers
# nginx injects, so the wrapper only sets non-secret public config.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env

VERSION="${VERSION:-$(git describe --tags --always --dirty 2>/dev/null || echo dev)}"

mkdir -p build

CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
  go build -trimpath -ldflags "-s -w -X main.version=${VERSION}" \
    -o "build/${APP}.bin" ./cmd/ledger

cat > "build/${APP}" <<'WRAPPER'
#!/usr/bin/env bash
set -euo pipefail
: "${METASPOT_DOMAIN:?metaspot-launch must have sourced /etc/metaspot/env}"
: "${PORT:?PORT must be set (etc/manifest.env)}"
# ledger is a path-routed service mounted at /srv/ledger/ behind nginx. Its canonical
# resource id is the public mount URL, and the AS it points clients at is the
# apex front door — both built from the bare account domain.
export LEDGER_RESOURCE_ID="https://${METASPOT_DOMAIN}/srv/ledger/mcp"
export LEDGER_AUTH_SERVER="https://${METASPOT_DOMAIN}"
export LEDGER_DB_PATH=/opt/ledger/data/ledger.db
exec /opt/ledger/bin/ledger.bin \
  --ip 127.0.0.1 \
  --port "${PORT}"
WRAPPER
chmod 0755 "build/${APP}"

echo "build/${APP}"
echo "build/${APP}.bin"
