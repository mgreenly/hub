#!/usr/bin/env bash
# bin/restore — replace the dashboard's live SQLite state from a backups-bucket
# snapshot. Symmetric with bin/backup's DB snapshot (stop / replace / start).
#
#   bin/restore [snapshot]
#     omitted            -> the newest snapshot (via <APP>/latest)
#     a bare UTC stamp   -> <APP>/dashboard.db.<stamp>.tar.gz
#     a full object key  -> used as-is
#
# DATA ONLY. Cert recovery is not here: bin/setup pulls <APP>/cert/latest itself
# when the box has no live cert, so the documented lifecycle is
# setup -> backup -> teardown -> setup (restores cert) -> restore (restores data,
# prior to deploy). Run restore after setup and before deploy.
#
# Destroys production state — always interactive, no --yes bypass. A pre-restore
# snapshot of the CURRENT db is pushed to <APP>/pre-restore/ first (kept: last
# 10, separate from the rolling-30 retention) so a wrong-snapshot mistake is
# recoverable.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$REPO/etc/manifest.env"
. "$REPO/etc/deploy.env"

HOST="${HOST:-${ACCOUNT}.metaspot.org}"
SSH_KEY="${SSH_KEY/#\~/$HOME}"
REQ="${1:-}"
SSH=(ssh -i "$SSH_KEY" "${SSH_USER}@${HOST}")

# ---- Phase A: resolve the target key on the box (read-only) ----
RESOLVED="$("${SSH[@]}" sudo APP="$APP" REQ="$REQ" bash -s <<'REMOTE'
set -euo pipefail
: "${APP:?}"
ENV_FILE=/etc/metaspot/env
[ -r "$ENV_FILE" ] || { echo "!! $ENV_FILE missing" >&2; exit 1; }
# shellcheck disable=SC1090
. "$ENV_FILE"
: "${METASPOT_BACKUP_BUCKET:?}"
export AWS_DEFAULT_REGION="${METASPOT_AWS_REGION:-us-east-2}"
B="$METASPOT_BACKUP_BUCKET"

if [ -z "${REQ:-}" ]; then
  KEY="$(aws s3 cp "s3://$B/${APP}/latest" - 2>/dev/null | tr -d '[:space:]')" || true
  [ -n "$KEY" ] || { echo "!! no ${APP}/latest pointer; pass an explicit snapshot" >&2; exit 1; }
elif [[ "$REQ" == */* ]]; then
  KEY="$REQ"
else
  KEY="${APP}/dashboard.db.${REQ}.tar.gz"
fi
aws s3api head-object --bucket "$B" --key "$KEY" >/dev/null 2>&1 \
  || { echo "!! snapshot s3://$B/$KEY not found" >&2; exit 1; }

echo "BUCKET=$B"
echo "KEY=$KEY"
echo "HOSTNAME=$(hostname)"
REMOTE
)"
eval "$(printf '%s\n' "$RESOLVED" | grep -E '^(BUCKET|KEY|HOSTNAME)=')"

# ---- Phase B: confirm on the workstation tty ----
echo
echo "  RESTORE — this overwrites live production state."
echo "    source : s3://$BUCKET/$KEY"
echo "    target : $HOSTNAME:/opt/${APP}/data/dashboard.db  (via $HOST)"
echo "    effect : ${APP} stopped, DB replaced, ${APP} restarted."
echo "    safety : a pre-restore snapshot of the current DB is taken first."
echo
printf '  Type "yes" to proceed: '
read -r ANS
[ "$ANS" = "yes" ] || { echo ">> aborted (no changes made)."; exit 1; }

# ---- Phase C: execute the destructive restore on the box ----
"${SSH[@]}" sudo APP="$APP" KEY="$KEY" bash -s <<'REMOTE'
set -euo pipefail
: "${APP:?}" "${KEY:?}"
ENV_FILE=/etc/metaspot/env
DATA_DIR="/opt/${APP}/data"
DB_BASENAME=dashboard.db
PRE_KEEP=10

# shellcheck disable=SC1090
. "$ENV_FILE"
export AWS_DEFAULT_REGION="${METASPOT_AWS_REGION:-us-east-2}"
BUCKET="$METASPOT_BACKUP_BUCKET"

WORK="$(mktemp -d)"
APP_WAS_STOPPED=0
cleanup() {
  if [ "$APP_WAS_STOPPED" = 1 ]; then
    systemctl is-active --quiet "${APP}" || systemctl start "${APP}" || true
  fi
  rm -rf "$WORK"
}
trap cleanup EXIT

echo ">> stopping ${APP}"
systemctl stop "${APP}" || true
APP_WAS_STOPPED=1

if [ -e "$DATA_DIR/$DB_BASENAME" ]; then
  PKEY="${APP}/pre-restore/${DB_BASENAME}.$(date -u +%Y%m%dT%H%M%SZ).tar.gz"
  tar -czf "$WORK/pre.tar.gz" -C "$DATA_DIR" \
    $(cd "$DATA_DIR" && ls "$DB_BASENAME"*)
  echo ">> pre-restore snapshot -> s3://$BUCKET/$PKEY"
  aws s3 cp --no-progress "$WORK/pre.tar.gz" "s3://$BUCKET/$PKEY"
  mapfile -t PKEYS < <(
    aws s3api list-objects-v2 --bucket "$BUCKET" --prefix "${APP}/pre-restore/${DB_BASENAME}." \
      --query 'sort_by(Contents,&Key)[].Key' --output text 2>/dev/null \
      | tr '\t' '\n' | sed '/^$/d' | grep -v '^None$' || true
  )
  if [ "${#PKEYS[@]}" -gt "$PRE_KEEP" ]; then
    for ((i = 0; i < ${#PKEYS[@]} - PRE_KEEP; i++)); do
      aws s3 rm "s3://$BUCKET/${PKEYS[$i]}"
    done
  fi
else
  echo ">> no current DB on box; skipping pre-restore snapshot"
fi

echo ">> downloading s3://$BUCKET/$KEY"
aws s3 cp --no-progress "s3://$BUCKET/$KEY" "$WORK/restore.tar.gz"
rm -f "$DATA_DIR/$DB_BASENAME" "$DATA_DIR/$DB_BASENAME"-*
tar -xzf "$WORK/restore.tar.gz" -C "$DATA_DIR"
chown -R "${APP}:${APP}" "$DATA_DIR"
chmod 0640 "$DATA_DIR/$DB_BASENAME"

echo ">> starting ${APP}"
systemctl start "${APP}"
APP_WAS_STOPPED=0
sleep 2
systemctl status "${APP}" --no-pager --lines=10 || true
echo ">> restore complete: s3://$BUCKET/$KEY -> $DATA_DIR/$DB_BASENAME"
REMOTE
